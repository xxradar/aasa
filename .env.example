# AI Agent Attack Surface Analyzer — Configuration
# Copy this to .env and fill in your values

# Anthropic API key for LLM-as-judge analysis (optional)
# Without this, only static rule-based analysis is available
AASA_ANTHROPIC_API_KEY=

# LLM model for judge analysis
AASA_LLM_MODEL=claude-sonnet-4-5-20250929

# Enable/disable LLM judge
AASA_LLM_JUDGE_ENABLED=true

# Crawler settings
AASA_MAX_DEPTH=2
AASA_MAX_PAGES=50
AASA_REQUEST_TIMEOUT=15
AASA_CONCURRENT_REQUESTS=5

# Server settings
AASA_HOST=0.0.0.0
AASA_PORT=6001
AASA_DEBUG=false
