# AI Agent Attack Surface Analyzer — Configuration
# Copy this to .env and fill in your values

# Anthropic API key for LLM-as-judge analysis (optional)
# Without this, only static rule-based analysis is available
AASA_ANTHROPIC_API_KEY=

# LLM model for judge analysis
AASA_LLM_MODEL=claude-sonnet-4-5-20250929

# Enable/disable LLM judge
AASA_LLM_JUDGE_ENABLED=true

# Crawler settings
AASA_MAX_DEPTH=2
AASA_MAX_PAGES=50
AASA_REQUEST_TIMEOUT=15
AASA_CONCURRENT_REQUESTS=5

# Server settings
AASA_HOST=0.0.0.0
AASA_PORT=6001
AASA_DEBUG=false

# Authentication
# Generate a real secret: openssl rand -hex 32
AASA_SECRET_KEY=
AASA_AUTH_ENABLED=true

# GitHub OAuth (optional — create at https://github.com/settings/applications/new)
# Callback URL: http://localhost:6001/auth/github/callback
AASA_GITHUB_CLIENT_ID=
AASA_GITHUB_CLIENT_SECRET=

# Google OAuth (optional — create at https://console.cloud.google.com/apis/credentials)
# Redirect URI: http://localhost:6001/auth/google/callback
AASA_GOOGLE_CLIENT_ID=
AASA_GOOGLE_CLIENT_SECRET=
